{
  "mcpServers": {
    "frontapp-erp-dev": {
      "command": "/Users/YOUR_USERNAME/.local/bin/uv",
      "args": ["run", "mcp-hmr", "src/frontapp_mcp/server.py:mcp"],
      "cwd": "/REPLACE/WITH/YOUR/PATH/TO/frontapp-openapi-client/frontapp_mcp_server",
      "env": {
        "FRONTAPP_API_KEY": "${FRONTAPP_API_KEY}",
        "FRONTAPP_BASE_URL": "https://api2.frontapp.com"
      }
    },
    "frontapp-erp": {
      "command": "frontapp-mcp-server",
      "env": {
        "FRONTAPP_API_KEY": "${FRONTAPP_API_KEY}",
        "FRONTAPP_BASE_URL": "https://api2.frontapp.com"
      }
    }
  }
}
